# Generate with: npx @514labs/express-pbkdf2-api-key-auth generate
# Or use: cd packages/moosestack-service && pnpm moose generate hash-token
# Leave unset for development (no auth required)
MCP_API_KEY=
JWKS_URL=
# Optional: Clerk issuer URL for JWT validation (e.g., https://<clerk-domain>)
JWT_ISSUER=
