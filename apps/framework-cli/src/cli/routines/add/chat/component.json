{
  "name": "chat",
  "kind": "nextjs",
  "language": "typescript",
  "template": "typescript-mcp",
  "base_path": "packages/web-app",
  "files": [
    { "src": "src/env-vars.ts", "dest": "src/env-vars.ts" },
    { "src": "src/hooks/use-mobile.ts", "dest": "src/hooks/use-mobile.ts" },
    { "src": "src/app/api/chat/route.ts", "dest": "src/app/api/chat/route.ts" },
    {
      "src": "src/app/api/chat/status/route.ts",
      "dest": "src/app/api/chat/status/route.ts"
    },
    {
      "src": "src/components/layout/chat-layout-wrapper.tsx",
      "dest": "src/components/layout/chat-layout-wrapper.tsx"
    },
    {
      "src": "src/components/layout/content-header.tsx",
      "dest": "src/components/layout/content-header.tsx"
    },
    {
      "src": "src/components/layout/resizable-chat-layout.tsx",
      "dest": "src/components/layout/resizable-chat-layout.tsx"
    },
    {
      "src": "src/features/chat/agent-config.ts",
      "dest": "src/features/chat/agent-config.ts"
    },
    {
      "src": "src/features/chat/chat-button.tsx",
      "dest": "src/features/chat/chat-button.tsx"
    },
    {
      "src": "src/features/chat/chat-input.tsx",
      "dest": "src/features/chat/chat-input.tsx"
    },
    {
      "src": "src/features/chat/chat-output-area.tsx",
      "dest": "src/features/chat/chat-output-area.tsx"
    },
    {
      "src": "src/features/chat/chat-ui.tsx",
      "dest": "src/features/chat/chat-ui.tsx"
    },
    {
      "src": "src/features/chat/clickhouse-tool-invocation.tsx",
      "dest": "src/features/chat/clickhouse-tool-invocation.tsx"
    },
    {
      "src": "src/features/chat/code-block.tsx",
      "dest": "src/features/chat/code-block.tsx"
    },
    {
      "src": "src/features/chat/get-agent-response.ts",
      "dest": "src/features/chat/get-agent-response.ts"
    },
    {
      "src": "src/features/chat/reasoning-section.tsx",
      "dest": "src/features/chat/reasoning-section.tsx"
    },
    {
      "src": "src/features/chat/source-section.tsx",
      "dest": "src/features/chat/source-section.tsx"
    },
    {
      "src": "src/features/chat/suggested-prompt.tsx",
      "dest": "src/features/chat/suggested-prompt.tsx"
    },
    {
      "src": "src/features/chat/system-prompt.ts",
      "dest": "src/features/chat/system-prompt.ts"
    },
    {
      "src": "src/features/chat/text-formatter.tsx",
      "dest": "src/features/chat/text-formatter.tsx"
    },
    {
      "src": "src/features/chat/tool-data-catalog.tsx",
      "dest": "src/features/chat/tool-data-catalog.tsx"
    },
    {
      "src": "src/features/chat/tool-invocation.tsx",
      "dest": "src/features/chat/tool-invocation.tsx"
    },
    {
      "src": "src/features/chat/use-anthropic-status.ts",
      "dest": "src/features/chat/use-anthropic-status.ts"
    },
    {
      "src": "src/components/theme-toggle.tsx",
      "dest": "src/components/theme-toggle.tsx"
    },
    {
      "src": "src/components/ui/resizable.tsx",
      "dest": "src/components/ui/resizable.tsx"
    }
  ],
  "moose_main_exports": null,
  "env": [
    {
      "file": ".env.local",
      "key": "ANTHROPIC_API_KEY",
      "placeholder": "# your Anthropic API key from https://console.anthropic.com"
    },
    {
      "file": ".env.local",
      "key": "MCP_API_TOKEN",
      "placeholder": "# run: moose generate hash-token, use the Bearer Token value"
    },
    {
      "file": ".env.development",
      "key": "MCP_SERVER_URL",
      "placeholder": "http://localhost:4000"
    }
  ],
  "npm_deps": [
    "ai@5.0.106",
    "@ai-sdk/anthropic@2.0.53",
    "@ai-sdk/mcp@0.0.7",
    "@ai-sdk/react@2.0.106",
    "react-markdown@^10.1.0",
    "remark-gfm@^4.0.1",
    "react-resizable-panels@^3.0.6",
    "lucide-react@^0.552.0",
    "class-variance-authority@^0.7.1",
    "next-themes@^0.2.1"
  ],
  "shadcn_components": [
    "badge",
    "button",
    "collapsible",
    "dropdown-menu",
    "scroll-area",
    "textarea"
  ],
  "docs": "  1. Generate auth tokens:  moose generate hash-token\n     Copy the Bearer Token into .env.local as MCP_API_TOKEN.\n  2. Get your Anthropic API key from https://console.anthropic.com\n     Copy it into .env.local as ANTHROPIC_API_KEY.\n  3. Add ChatLayoutWrapper to your layout or page:\n       import { ChatLayoutWrapper } from \"@/components/layout/chat-layout-wrapper\";\n       <ChatLayoutWrapper>{children}</ChatLayoutWrapper>\n  4. Start both moose and web apps\n"
}
